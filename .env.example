# Telegram ayarlari (BotFather'dan alinir)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# --- Opsiyonel ayarlar (degistirmek istemezsen silebilirsin) ---
# Hedef ETF'ler
ASSETS_BULL=MSTU,MSTX
ASSETS_BEAR=MSTZ

# Sinyal esikleri
SIGNAL_SCORE_THRESHOLD=40      # |skor| bu degeri gecince tam sinyal
WATCH_SCORE_THRESHOLD=22       # |skor| bu degeri gecince erken uyari
ADX_MIN=20                     # trendin "gercek" sayilmasi icin min ADX
ALERT_COOLDOWN_HOURS=4         # ayni yonde tekrar sinyal icin bekleme

# Kripto'ya ozgu ongoru verileri (Binance Futures)
USE_FUTURES_SENTIMENT=true     # funding rate + open interest kullan

# Alpaca (OPSIYONEL) - ETF fiyatlari icin ~gercek zamanli (ucretsiz IEX feed).
# Bos birakirsan otomatik yfinance kullanilir (~15dk gecikmeli).
# Anahtarlari https://app.alpaca.markets > Home/API Keys'ten al (paper hesap yeterli).
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_FEED=iex

# Pozisyon / risk
UNDERLYING=MSTR                # ETF'lerin takip ettigi hisse (grafik + baz riski)
ATR_STOP_MULT=2.0             # stop = giris -/+ N*ATR
MAX_HOLD_HOURS=48            # zaman bazli cikis
MARKET_HOURS_ONLY=false      # true ise ABD seansi kapaliyken tam sinyali erken uyariya dusurur

# Sanal portfoy (paper trading) - botun gercek basarisini olcer
PAPER_TRADING=true
PAPER_START_EQUITY=10000     # baslangic sermayesi ($)
PAPER_ALLOC_PCT=100          # her sinyalde sermayenin %'si
PAPER_FEE_PCT=0.1            # islem basina komisyon+spread (%)
